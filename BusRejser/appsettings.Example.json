{
  "ConnectionStrings": {
    "DefaultConnection": "server=localhost;port=3307;database=busplanen;user=bususer;password=replace-me;"
  },
  "Jwt": {
    "Secret": "replace-with-at-least-32-characters",
    "Issuer": "BusPlanen.Api",
    "Audience": "BusPlanen.Client",
    "AccessTokenLifetimeMinutes": 60
  },
  "Auth": {
    "RefreshTokenLifetimeDays": 14,
    "RequireConfirmedEmail": false
  },
  "Stripe": {
    "SecretKey": "replace-with-stripe-secret-key",
    "WebhookSecret": "replace-with-stripe-webhook-secret"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  },
  "Frontend": {
    "BaseUrl": "http://localhost:5173",
    "PaymentSuccessPath": "/betaling/success",
    "PaymentCancelPath": "/betaling/cancel",
    "PasswordResetPath": "/reset-password"
  },
  "RateLimiting": {
    "Login": {
      "PermitLimit": 5,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "Register": {
      "PermitLimit": 5,
      "WindowSeconds": 300,
      "QueueLimit": 0
    },
    "ForgotPassword": {
      "PermitLimit": 3,
      "WindowSeconds": 300,
      "QueueLimit": 0
    },
    "ResetPassword": {
      "PermitLimit": 5,
      "WindowSeconds": 300,
      "QueueLimit": 0
    },
    "RefreshToken": {
      "PermitLimit": 20,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "CheckoutCreate": {
      "PermitLimit": 10,
      "WindowSeconds": 300,
      "QueueLimit": 0
    },
    "CheckoutStatus": {
      "PermitLimit": 30,
      "WindowSeconds": 60,
      "QueueLimit": 0
    }
  },
  "Email": {
    "Host": "sandbox.smtp.mailtrap.io",
    "Port": 587,
    "Username": "replace-with-email-username",
    "Password": "replace-with-email-password",
    "From": "noreply@example.com"
  }
}
